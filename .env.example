# Server Configuration
PORT=3000
BASE_URL=https://your-domain.com

# API Authentication (used by LB-Phone / FiveM scripts)
# Generate a strong random key: openssl rand -hex 32
API_KEY=change-me-to-a-strong-random-key

# Admin Dashboard Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-64-char-hex-secret

# CORS Configuration
# Set to your domain for browser-based clients, e.g.: https://your-domain.com
# Leave empty or set to "false" to disable CORS
# CORS_ORIGIN=
